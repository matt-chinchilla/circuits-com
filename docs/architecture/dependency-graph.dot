    "public/pages/home";
    "public/pages/home/components/CategoryCard";
    "public/pages/home/components/CategoryGrid";
    "public/pages/home/components/HeroSection";
    "public/pages/join";
    "public/pages/keyword";
    "public/pages/part";
    "public/pages/search";
    "public/services/api";
    "public/types/category";
    "public/types/part";
    "public/types/sponsor";
    "public/types/supplier";
  }

  subgraph cluster_admin {
    label="admin/";
    style=filled; fillcolor="#fff0e0"; fontsize=14;
    node [fillcolor="#ffd699"];
    "admin/components/AdminLayout";
    "admin/components/Breadcrumbs";
    "admin/components/ConfirmDialog";
    "admin/components/DataTable";
    "admin/components/DemoToggle";
    "admin/components/ProtectedRoute";
    "admin/components/StatCard";
    "admin/contexts/AuthContext";
    "admin/contexts/DemoContext";
    "admin/pages/categories";
    "admin/pages/dashboard";
    "admin/pages/import";
    "admin/pages/login";
    "admin/pages/parts/detail";
    "admin/pages/parts/form";
    "admin/pages/parts/list";
    "admin/pages/placeholder";
    "admin/pages/reports";
    "admin/pages/settings";
    "admin/pages/sponsors/form";
    "admin/pages/sponsors/list";
    "admin/pages/suppliers/detail";
    "admin/pages/suppliers/form";
    "admin/pages/suppliers/list";
    "admin/services/adminApi";
    "admin/types/admin";
  }

  subgraph cluster_shared {
    label="shared/";
    style=filled; fillcolor="#e8f5e8"; fontsize=14;
    node [fillcolor=lightgreen];
    "shared/services/constants";
  }

  // === EXTERNAL DEPENDENCIES ===
  "axios" [shape=ellipse, fillcolor=lightgrey];
  "framer-motion" [shape=ellipse, fillcolor=lightgrey];
  "lucide-react" [shape=ellipse, fillcolor=lightgrey];
  "papaparse" [shape=ellipse, fillcolor=lightgrey];
  "react" [shape=ellipse, fillcolor=lightgrey];
  "react-dom/client" [shape=ellipse, fillcolor=lightgrey];
  "react-dropzone" [shape=ellipse, fillcolor=lightgrey];
  "react-router-dom" [shape=ellipse, fillcolor=lightgrey];

