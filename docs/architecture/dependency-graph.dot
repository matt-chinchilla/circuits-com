    "public/components/widgets/SkeletonLoader";
    "public/hooks/useAnimateOnScroll";
    "public/hooks/useCategories";
    "public/hooks/useSearch";
    "public/pages/about";
    "public/pages/category";
    "public/pages/category/components/LayoutSwitcher";
    "public/pages/category/components/PartsTable";
    "public/pages/category/components/SponsorBlock";
    "public/pages/category/components/SubcategoryChips";
