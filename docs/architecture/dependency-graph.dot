digraph FrontendDependencies {
  rankdir=LR;
  fontname="Helvetica";
  node [shape=box, style=filled, fontname="Helvetica", fontsize=10];
  edge [color="#999999", arrowsize=0.6];

  // === ROOT ENTRY POINTS ===
  "App" [fillcolor=gold];
  "main" [fillcolor=gold];

  subgraph cluster_public {
    label="public/";
    style=filled; fillcolor="#e6f3ff"; fontsize=14;
    node [fillcolor=lightblue];
    "public/components/layout/BackdropLayer";
    "public/components/layout/Footer";
    "public/components/layout/NavVariantPicker";
